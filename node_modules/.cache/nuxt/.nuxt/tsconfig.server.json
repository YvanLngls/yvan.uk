{
  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "resolveJsonModule": true,
    "jsx": "preserve",
    "allowSyntheticDefaultImports": true,
    "jsxFactory": "h",
    "jsxFragmentFactory": "Fragment",
    "paths": {
      "#imports": [
        "./types/nitro-imports"
      ],
      "~/*": [
        "../../../../app/*"
      ],
      "@/*": [
        "../../../../app/*"
      ],
      "~~/*": [
        "../../../../*"
      ],
      "@@/*": [
        "../../../../*"
      ],
      "vue-router": [
        "../../../vue-router"
      ],
      "vue-router/auto-routes": [
        "../../../vue-router/vue-router-auto-routes"
      ],
      "nuxt": [
        "../../../nuxt"
      ],
      "@unhead/vue": [
        "../../../@unhead/vue"
      ],
      "@nuxt/devtools": [
        "../../../@nuxt/devtools"
      ],
      "vue": [
        "../../../vue"
      ],
      "@vue/runtime-core": [
        "../../../@vue/runtime-core"
      ],
      "@vue/compiler-sfc": [
        "../../../@vue/compiler-sfc"
      ],
      "@nuxt/schema": [
        "../../../@nuxt/schema"
      ],
      "@nuxt/icon": [
        "../../../@nuxt/icon"
      ],
      "@nuxt/fonts": [
        "../../../@nuxt/fonts"
      ],
      "@nuxtjs/color-mode": [
        "../../../@nuxtjs/color-mode"
      ],
      "@nuxtjs/mdc": [
        "../../../@nuxtjs/mdc"
      ],
      "vue-i18n": [
        "../../../vue-i18n"
      ],
      "@intlify/shared": [
        "../../../@intlify/shared"
      ],
      "@intlify/core": [
        "../../../@intlify/core"
      ],
      "@intlify/core-base": [
        "../../../@intlify/core-base"
      ],
      "@intlify/utils": [
        "../../../@intlify/utils"
      ],
      "@intlify/utils/h3": [
        "../../../@intlify/utils"
      ],
      "@intlify/message-compiler": [
        "../../../@intlify/message-compiler"
      ],
      "defu": [
        "../../../defu"
      ],
      "h3": [
        "../../../h3"
      ],
      "consola": [
        "../../../consola"
      ],
      "ofetch": [
        "../../../ofetch"
      ],
      "crossws": [
        "../../../crossws"
      ],
      "vite/client": [
        "../../../vite/client"
      ],
      "nitropack/types": [
        "../../../nitropack/types"
      ],
      "nitropack/runtime": [
        "../../../nitropack/runtime"
      ],
      "nitropack": [
        "../../../nitropack"
      ],
      "#content/components": [
        "./content/components"
      ],
      "#content/manifest": [
        "./content/manifest"
      ],
      "#shared": [
        "../../../../shared"
      ],
      "#shared/*": [
        "../../../../shared/*"
      ],
      "#server": [
        "../../../../server"
      ],
      "#server/*": [
        "../../../../server/*"
      ],
      "#build": [
        "./"
      ],
      "#build/*": [
        "./*"
      ],
      "#internal/nuxt/paths": [
        "../../../@nuxt/nitro-server/dist/runtime/utils/paths"
      ],
      "#ui": [
        "../../../@nuxt/ui/dist/runtime"
      ],
      "#ui/*": [
        "../../../@nuxt/ui/dist/runtime/*"
      ],
      "#i18n": [
        "../../../@nuxtjs/i18n/dist/runtime/composables/index-server"
      ],
      "#i18n-kit": [
        "../../../@nuxtjs/i18n/dist/runtime/kit"
      ],
      "#i18n-kit/*": [
        "../../../@nuxtjs/i18n/dist/runtime/kit/*"
      ],
      "#internal-i18n-types": [
        "../../../@nuxtjs/i18n/dist/types"
      ],
      "#unhead/composables": [
        "../../../nuxt/dist/head/runtime/composables"
      ],
      "#color-mode-options": [
        "./color-mode-options.mjs"
      ],
      "#mdc-configs": [
        "./mdc-configs"
      ],
      "#mdc-highlighter": [
        "./mdc-highlighter"
      ],
      "#mdc-imports": [
        "./mdc-imports"
      ],
      "#nuxt-icon-server-bundle": [
        "./nuxt-icon-server-bundle"
      ],
      "#content/dump": [
        "./content/database.compressed"
      ],
      "#content/adapter": [
        "./db0/connectors/better-sqlite3"
      ],
      "#content/local-adapter": [
        "./db0/connectors/better-sqlite3"
      ]
    },
    "lib": [
      "esnext",
      "webworker",
      "dom.iterable"
    ],
    "noUncheckedIndexedAccess": true,
    "allowArbitraryExtensions": true
  },
  "include": [
    "./content/types.d.ts",
    "./types/nitro-nuxt.d.ts",
    "../../../runtime/server",
    "../../../dist/runtime/server",
    "../../../../server/**/*",
    "../../../../shared/**/*.d.ts",
    "./types/nitro.d.ts"
  ],
  "exclude": [
    "../../..",
    "../../../nuxt/node_modules",
    "../../../@nuxt/eslint/node_modules",
    "../../../@nuxt/ui/node_modules",
    "../../../@nuxtjs/i18n/node_modules",
    "../../../@nuxt/content/node_modules",
    "../../../@vueuse/motion/node_modules",
    "../../../@nuxt/devtools/node_modules",
    "../../../@nuxt/telemetry/node_modules",
    "../../../@nuxt/icon/node_modules",
    "../../../@nuxt/fonts/node_modules",
    "../../../@nuxtjs/color-mode/node_modules",
    "../../../@nuxtjs/mdc/node_modules",
    "../../../../dist"
  ]
}